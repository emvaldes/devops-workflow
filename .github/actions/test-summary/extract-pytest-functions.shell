#!/usr/bin/env bash
## Version: 0.1.0

# set -x ;
set -e ;           # Exit on error
set -o pipefail ;  # Fail if any piped command fails

## extract-pytest-functions \
##   --pytests-location="tests/requirements/dependencies" \
##   --dry-run \
##   --verbose ;

function extract_pytests_functions () {
    ## tracking_process ${FUNCNAME} "${@}";
    oIFS="${IFS}";
    for xitem in "${@}"; do
      IFS='='; set `echo -e "${xitem}" | sed -e '1s|^\(-\)\{1,\}||'`
      [[ ${1#*\--} = "pytests-location" ]] && local pytests_location="${2}";
      [[ ${1#*\--} = "scripts-location" ]] && local scripts_location="${2}";
      [[ ${1#*\--} = "output-filename" ]] && local output_filename="${2}";
      #### ---------------------------------------------------------------------
      ## [[ ${1#*\--} = "dry-run" ]] && local dry_run="${2}";
      [[ ${1#*\--} = "verbose" ]] && local verbose='true';
    done; IFS="${oIFS}";
    #### -----------------------------------------------------------------------
    ## [[ ${#dry_run} -eq 0 ]] && local dry_run='false';
    [[ ${#verbose} -eq 0 ]] && local verbose='false';
    #### -----------------------------------------------------------------------

    ## Define custom-parameter(s):
    if [[ ${#pytests_location} -eq 0 ]]; then
            echo -e "Error: PyTests Location is invalid or not provided!";
            exit 1;
            # Ensure the file exists before proceeding
      else  if [[ ! -e "${pytests_location}" ]]; then
              echo -e "ERROR: Target location was not found: ${pytests_location}";
              echo -e '{"test_functions": ["dummy_test_function"]}' > "${output_filename}";
              exit 1;
            fi;
    fi;
    if [[ ${#scripts_location} -eq 0 ]]; then
      scripts_location="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )";
    fi;
    if [[ ${#pytests_location} -eq 0 ]]; then
      local output_filename="test_functions.json";
    fi;

    # pytests_location="tests/requirements/dependencies/test_dependencies.py" ;
    echo -e "\nExtracting test functions from: ${pytests_location}";

    ## Find all test_*.py files recursively
    test_files=($(
      find "${pytests_location}" -type f -name "test_*.py"
    ));
    if [[ ${#test_files[@]} -eq 0 ]]; then
            echo -e "ERROR: No test files found in '${pytests_location}'!";
            echo -e '{"test_functions": ["dummy_test_function"]}' > "${output_filename}";
            exit 1;
      # else  echo -e "\nPyTest files list:\n${test_files[@]}";
    fi;

    ## Convert Bash array to a properly formatted JSON array
    json_list=$( printf '%s\n' "${test_files[@]}" | jq -R . | jq -s . );
    # echo -e "PyTest files JSON:\n${json_list}\n";

    echo -en "python3 ${scripts_location}/extract-pytest-functions.py ";
    echo -e  "${json_list}\n${output_filename}";

    ## Call the external Python script instead of using here-doc
    python3 ${scripts_location}/extract-pytest-functions.py \
        "${json_list}" "${output_filename}";

    echo -e "\nExtracted test functions saved to: ${output_filename}";
    ls -al ${output_filename};

    ## Flatten JSON: Extract functions into a single list
    jq '[.test_functions | to_entries[] | .value[]]' ${output_filename} > test_functions_flat.json;
    mv test_functions_flat.json ${output_filename};

    # Validate JSON before proceeding
    if ! jq -e . ${output_filename} > /dev/null 2>&1; then
        echo -e "ERROR: ${output_filename} is not valid JSON!";
        cat ${output_filename};
        exit 1;
    fi;

    echo -e "\nGenerated JSON Output:";
    cat ${output_filename};

    return 0;
  }; alias extract-pytest-functions='extract_pytests_functions';

extract_pytests_functions "${@}";
